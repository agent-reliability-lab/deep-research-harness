{
  "$defs": {
    "CitationExpectations": {
      "additionalProperties": false,
      "properties": {
        "minimum_citations": {
          "minimum": 1,
          "title": "Minimum Citations",
          "type": "integer"
        },
        "minimum_unique_sources": {
          "minimum": 1,
          "title": "Minimum Unique Sources",
          "type": "integer"
        }
      },
      "required": [
        "minimum_citations",
        "minimum_unique_sources"
      ],
      "title": "CitationExpectations",
      "type": "object"
    },
    "ClaimScoringMethod": {
      "enum": [
        "pattern_contract",
        "llm_judge"
      ],
      "title": "ClaimScoringMethod",
      "type": "string"
    },
    "ClaimVerificationStatus": {
      "enum": [
        "draft",
        "verified"
      ],
      "title": "ClaimVerificationStatus",
      "type": "string"
    },
    "EvaluationMode": {
      "enum": [
        "deterministic_fixture",
        "deterministic_benchmark",
        "judge_required"
      ],
      "title": "EvaluationMode",
      "type": "string"
    },
    "RequiredClaim": {
      "additionalProperties": false,
      "properties": {
        "claim_id": {
          "minLength": 1,
          "pattern": "^[a-z0-9][a-z0-9._-]*$",
          "title": "Claim Id",
          "type": "string"
        },
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "verification_status": {
          "$ref": "#/$defs/ClaimVerificationStatus"
        },
        "scoring_method": {
          "$ref": "#/$defs/ClaimScoringMethod"
        },
        "acceptable_source_ids": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Acceptable Source Ids",
          "type": "array"
        },
        "evidence_patterns": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Evidence Patterns",
          "type": "array"
        },
        "answer_pattern_groups": {
          "items": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "minItems": 1,
          "title": "Answer Pattern Groups",
          "type": "array"
        }
      },
      "required": [
        "claim_id",
        "description",
        "verification_status",
        "scoring_method",
        "acceptable_source_ids",
        "evidence_patterns",
        "answer_pattern_groups"
      ],
      "title": "RequiredClaim",
      "type": "object"
    },
    "SourceRequirement": {
      "additionalProperties": false,
      "properties": {
        "source_id": {
          "minLength": 1,
          "pattern": "^[a-z0-9][a-z0-9._-]*$",
          "title": "Source Id",
          "type": "string"
        },
        "source_type": {
          "$ref": "#/$defs/SourceType"
        },
        "canonical_url": {
          "format": "uri",
          "minLength": 1,
          "title": "Canonical Url",
          "type": "string"
        },
        "url_checked_at": {
          "format": "date",
          "title": "Url Checked At",
          "type": "string"
        },
        "required_topics": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Required Topics",
          "type": "array"
        },
        "selection_rationale": {
          "minLength": 1,
          "title": "Selection Rationale",
          "type": "string"
        }
      },
      "required": [
        "source_id",
        "source_type",
        "canonical_url",
        "url_checked_at",
        "required_topics",
        "selection_rationale"
      ],
      "title": "SourceRequirement",
      "type": "object"
    },
    "SourceType": {
      "enum": [
        "synthetic_fixture",
        "official_docs",
        "official_repository",
        "research_paper",
        "third_party_analysis"
      ],
      "title": "SourceType",
      "type": "string"
    },
    "TaskFamily": {
      "enum": [
        "architecture_comparison",
        "memory_lifecycle",
        "retrieval_ranking",
        "operations",
        "product_recommendation"
      ],
      "title": "TaskFamily",
      "type": "string"
    },
    "TaskLifecycle": {
      "enum": [
        "draft",
        "frozen"
      ],
      "title": "TaskLifecycle",
      "type": "string"
    },
    "TaskRubric": {
      "additionalProperties": false,
      "properties": {
        "minimum_required_claim_coverage": {
          "maximum": 1,
          "minimum": 0,
          "title": "Minimum Required Claim Coverage",
          "type": "number"
        },
        "minimum_citation_precision": {
          "maximum": 1,
          "minimum": 0,
          "title": "Minimum Citation Precision",
          "type": "number"
        },
        "minimum_citation_entailment": {
          "maximum": 1,
          "minimum": 0,
          "title": "Minimum Citation Entailment",
          "type": "number"
        },
        "maximum_distractor_mentions": {
          "default": 0,
          "minimum": 0,
          "title": "Maximum Distractor Mentions",
          "type": "integer"
        }
      },
      "required": [
        "minimum_required_claim_coverage",
        "minimum_citation_precision",
        "minimum_citation_entailment"
      ],
      "title": "TaskRubric",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "default": "0.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "task_id": {
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9._-]*$",
      "title": "Task Id",
      "type": "string"
    },
    "task_version": {
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "title": "Task Version",
      "type": "string"
    },
    "rubric_version": {
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "title": "Rubric Version",
      "type": "string"
    },
    "lifecycle": {
      "$ref": "#/$defs/TaskLifecycle"
    },
    "family": {
      "$ref": "#/$defs/TaskFamily"
    },
    "prompt": {
      "minLength": 1,
      "title": "Prompt",
      "type": "string"
    },
    "fixture_only": {
      "title": "Fixture Only",
      "type": "boolean"
    },
    "evaluation_mode": {
      "$ref": "#/$defs/EvaluationMode"
    },
    "source_snapshot_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Source Snapshot Id"
    },
    "source_requirements": {
      "items": {
        "$ref": "#/$defs/SourceRequirement"
      },
      "minItems": 1,
      "title": "Source Requirements",
      "type": "array"
    },
    "required_claims": {
      "items": {
        "$ref": "#/$defs/RequiredClaim"
      },
      "minItems": 1,
      "title": "Required Claims",
      "type": "array"
    },
    "acceptable_source_ids": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Acceptable Source Ids",
      "type": "array"
    },
    "known_distractors": {
      "items": {
        "type": "string"
      },
      "title": "Known Distractors",
      "type": "array"
    },
    "required_comparison_dimensions": {
      "items": {
        "type": "string"
      },
      "title": "Required Comparison Dimensions",
      "type": "array"
    },
    "citation_expectations": {
      "$ref": "#/$defs/CitationExpectations"
    },
    "rubric": {
      "$ref": "#/$defs/TaskRubric"
    }
  },
  "required": [
    "task_id",
    "task_version",
    "rubric_version",
    "lifecycle",
    "family",
    "prompt",
    "fixture_only",
    "evaluation_mode",
    "source_snapshot_id",
    "source_requirements",
    "required_claims",
    "acceptable_source_ids",
    "citation_expectations",
    "rubric"
  ],
  "title": "BenchmarkTask",
  "type": "object"
}
