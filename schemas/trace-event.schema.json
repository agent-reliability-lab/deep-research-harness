{
  "$defs": {
    "CallCost": {
      "additionalProperties": false,
      "properties": {
        "input_usd": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "default": "0",
          "title": "Input Usd"
        },
        "output_usd": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "default": "0",
          "title": "Output Usd"
        },
        "cache_usd": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "default": "0",
          "title": "Cache Usd"
        }
      },
      "title": "CallCost",
      "type": "object"
    },
    "CallStatus": {
      "enum": [
        "success",
        "error"
      ],
      "title": "CallStatus",
      "type": "string"
    },
    "ChatMessage": {
      "additionalProperties": false,
