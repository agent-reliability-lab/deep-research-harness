# Copy to .env and fill in. .env is gitignored — never commit real keys.

# DeepSeek (primary provider). Key: https://platform.deepseek.com
DEEPSEEK_API_KEY=

# Exact model id under qualification. Spec primary is deepseek-v4-flash.
# Confirm the callable id in the DeepSeek console; G1 fails on any mismatch.
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional: comma-separated allowlist if the API returns a documented alias
# in addition to the requested id. Defaults to just DEEPSEEK_MODEL.
# DEEPSEEK_MODEL_ALLOWLIST=deepseek-v4-flash

# G2 uses three fixed requests because DeepSeek cache construction is
# asynchronous and best-effort. Increase only if the provider is unusually slow.
DEEPSEEK_CACHE_SETTLE_SECONDS=3

# AiHubMix (external-validity subset only; qualified later, not on the main path).
AIHUBMIX_API_KEY=
